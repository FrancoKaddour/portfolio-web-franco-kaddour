# Security Headers
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://formspree.io https://www.google-analytics.com https://analytics.google.com https://www.googletagmanager.com;

# No cache for HTML — always revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Cache static assets aggressively (Vite adds content hashes)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache images
/img/*
  Cache-Control: public, max-age=31536000, immutable

# Cache logos
/logos/*
  Cache-Control: public, max-age=31536000, immutable

# Cache favicons
/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.ico
  Cache-Control: public, max-age=31536000, immutable

/*.webmanifest
  Cache-Control: public, max-age=604800
