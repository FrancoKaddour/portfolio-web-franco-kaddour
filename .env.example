# Google Analytics 4
# 1. Crear propiedad en https://analytics.google.com
# 2. Obtener el Measurement ID (formato: G-XXXXXXXXXX)
# 3. Copiar este archivo como .env.local y completar el valor
VITE_GA_ID=G-XXXXXXXXXX

# Formspree (formulario de contacto)
# 1. Crear cuenta en https://formspree.io
# 2. Crear un nuevo form
# 3. Copiar el Form ID (formato: xkgwbqpz)
VITE_FORMSPREE_ID=YOUR_FORM_ID
